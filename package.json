{
  "name": "express-api",
  "version": "1.0.0",
  "description": "A minimal Express.js API with TypeScript and Jest",
  "keywords": [
    "express",
    "node",
    "typescript",
    "backend",
    "express",
    "docker",
    "jest",
    "eslint",
    "prettier"
  ],
  "license": "ISC",
  "author": "Justin van Dijk",
  "type": "commonjs",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.14.0",
  "scripts": {
    "prepare": "node .husky/install.mjs",
    "prepare:gui": "sh .husky/setup-gui.sh",
    "dev": "tsx watch src/index.ts",
    "dev:docker": "docker compose up app-dev --watch",
    "build": "tsc",
    "start": "node dist/index.js",
    "eslint": "eslint .",
    "prettier": "prettier --check .",
    "format": "prettier --write .",
    "lint": "pnpm run eslint && pnpm run prettier",
    "test": "jest"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.6",
    "eslint": "^10.0.3",
    "eslint-config-jvd": "^1.1.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "tsx": "latest",
    "typescript": "latest"
  },
  "prettier": "eslint-config-jvd/prettier",
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
